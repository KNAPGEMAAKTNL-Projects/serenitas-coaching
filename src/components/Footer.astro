---
/**
 * Footer — Copyright, legal links, contact.
 * DESIGN.md §16 (legal footer requirements), CONTENT/homepage.md Footer section.
 * Uses middot separator (F-005/F-008: zero dashes).
 */
---

<footer class="py-10 px-6" style="background-color: var(--color-text); color: rgba(255,255,255,0.5);">
  <div class="mx-auto flex flex-col gap-4 items-center text-center md:flex-row md:justify-between md:text-left" style="max-width: var(--w-content); font-size: 0.64rem;">
    <span>&copy; 2026 Serenitas Coaching &middot; Marcel Zoeteman</span>
    <div class="flex gap-6">
      <a href="/privacy" class="transition-colors duration-300 hover:text-white/80" style="color: rgba(255,255,255,0.5); transition-timing-function: var(--ease-project);">Privacy</a>
      <a href="/contact" class="transition-colors duration-300 hover:text-white/80" style="color: rgba(255,255,255,0.5); transition-timing-function: var(--ease-project);">Contact</a>
    </div>
  </div>
</footer>
