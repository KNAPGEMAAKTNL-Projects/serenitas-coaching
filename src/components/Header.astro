---
/**
 * Header — Fixed navigation with scroll-transparent behavior.
 * DESIGN.md §5 (nav CTA), §6 (nav container 80rem), §10 (underline hover), §12 (CTA: form primary).
 * Copy: CONTENT/homepage.md Nav table.
 * JS budget: ~0.8KB for scroll detection + mobile toggle + outside click.
 * Uses astro:page-load for ClientRouter compatibility.
 */
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navLinks = [
  { href: '/over-marcel', label: 'Over Marcel' },
  { href: '/werkwijze', label: 'Hoe ik werk' },
  { href: '/voor-wie', label: 'Voor wie' },
  { href: '/ervaringen', label: 'Ervaringen' },
  { href: '/contact', label: 'Contact' },
];
---

<nav
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 px-6 py-5 transition-all duration-300"
  style="transition-timing-function: var(--ease-project);"
  data-current-path={currentPath}
>
  <div class="mx-auto flex items-center justify-between" style="max-width: var(--w-nav);">
    <!-- Brand -->
    <a href="/" class="text-text no-underline" style="font-family: var(--font-heading); font-size: 1.25rem; font-weight: 500; letter-spacing: -0.01em;" transition:name="brand">
      Serenitas
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'nav-link transition-colors duration-300',
              currentPath === link.href ? 'nav-link--active' : ''
            ]}
            style={`font-size: 0.8rem; color: ${currentPath === link.href ? 'var(--color-text)' : 'var(--color-text-muted)'}; transition-timing-function: var(--ease-project);`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/contact"
          class="inline-block font-medium transition-colors duration-300 hover:bg-primary-deep"
          style="font-size: 0.8rem; color: #FFFFFF; background-color: var(--color-primary-dark); padding: 0.5rem 1.25rem; border-radius: 4px; transition-timing-function: var(--ease-project);"
        >
          Kennismaken
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger — min 44px touch target -->
    <button
      id="mobile-toggle"
      class="flex md:hidden flex-col justify-center items-center gap-[5px] cursor-pointer bg-transparent border-none"
      style="width: 44px; height: 44px; padding: 10px;"
      aria-label="Menu openen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block h-[2px] w-6 rounded-sm transition-transform duration-300" style="background-color: var(--color-text); transition-timing-function: var(--ease-project);"></span>
      <span class="block h-[2px] w-6 rounded-sm transition-opacity duration-300" style="background-color: var(--color-text); transition-timing-function: var(--ease-project);"></span>
      <span class="block h-[2px] w-[70%] rounded-sm transition-transform duration-300" style="background-color: var(--color-text); max-width: 1.05rem; transition-timing-function: var(--ease-project);"></span>
    </button>
  </div>

  <!-- Mobile menu panel (slide-down, not overlay — A2 animation level) -->
  <div
    id="mobile-menu"
    class="hidden md:hidden mt-4 pb-4"
    role="menu"
  >
    <ul class="flex flex-col gap-1">
      {navLinks.map(link => (
        <li role="menuitem">
          <a
            href={link.href}
            class="mobile-nav-link block py-3 px-2"
            style={`font-size: 0.875rem; color: ${currentPath === link.href ? 'var(--color-text)' : 'var(--color-text-muted)'}; min-height: 44px; display: flex; align-items: center;`}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2" role="menuitem">
        <a
          href="/contact"
          class="inline-block font-medium"
          style="font-size: 0.875rem; color: #FFFFFF; background-color: var(--color-primary-dark); padding: 0.75rem 1.5rem; border-radius: 4px; min-height: 44px; display: flex; align-items: center; justify-content: center;"
        >
          Kennismaken
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  // Re-runs on every page navigation (ClientRouter compatibility)
  document.addEventListener('astro:page-load', () => {
    const nav = document.getElementById('nav');
    const toggle = document.getElementById('mobile-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!nav) return;

    // ── Scroll: transparent → white with border ──
    function updateNav() {
      if (window.scrollY > 40) {
        nav.style.background = 'rgba(255,255,255,0.95)';
        nav.style.backdropFilter = 'blur(8px)';
        nav.style.boxShadow = '0 1px 0 var(--color-border)';
      } else {
        nav.style.background = 'transparent';
        nav.style.backdropFilter = 'none';
        nav.style.boxShadow = 'none';
      }
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => { updateNav(); ticking = false; });
        ticking = true;
      }
    }, { passive: true });
    updateNav();

    // ── Mobile toggle ──
    if (toggle && menu) {
      function closeMenu() {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        updateNav(); // Restore scroll-based background
      }

      function openMenu() {
        menu.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        // Force solid background when menu is open
        nav.style.background = 'rgba(255,255,255,0.98)';
        nav.style.backdropFilter = 'blur(8px)';
        nav.style.boxShadow = '0 1px 0 var(--color-border)';
      }

      toggle.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden');
        if (isOpen) { closeMenu(); } else { openMenu(); }
      });

      // Close on link click
      menu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (!nav.contains(e.target as Node) && !menu.classList.contains('hidden')) {
          closeMenu();
        }
      });

      // Close on Escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
          closeMenu();
          toggle.focus();
        }
      });
    }
  });
</script>
